                              "type": "text",
                              "id": "6NebW",
                              "name": "para2",
                              "fill": "#1F1F1F",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "系统使用 Yjs 作为 CRDT 引擎，所有文档编辑操作被转化为 Y.Doc 的 update 包。这些 update 包通过 libp2p 的 GossipSub 协议在 P2P 网络中广播。",
                              "lineHeight": 1.8,
                              "fontFamily": "Inter",
                              "fontSize": 15,
                              "fontWeight": "normal"
