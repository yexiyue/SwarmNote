                        {
                          "type": "text",
                          "id": "Bg3yB",
                          "name": "para1",
                          "fill": "#E5E5E5",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "SwarmNote 是一个去中心化的实时协同编辑器，基于 CRDT (Conflict-free Replicated Data Types) 和 P2P 网络构建。本文档描述其核心架构设计。",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "QfZC4",
                          "name": "h2",
                          "fill": "#FFFFFF",
                          "content": "## 数据同步层",
                          "fontFamily": "Inter",
                          "fontSize": 22,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "9txF8",
                          "name": "para2",
                          "fill": "#E5E5E5",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "系统使用 Yjs 作为 CRDT 引擎，所有文档编辑操作被转化为 Y.Doc 的 update 包。这些 update 包通过 libp2p 的 GossipSub 协议在 P2P 网络中广播。",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "c0qXr",
                          "name": "CodeBlock",
                          "width": "fill_container",
                          "fill": "#141414",
                          "cornerRadius": 8,
                          "stroke": {
                            "thickness": 1,
                            "fill": "#2A2A2A"
                          },
                          "layout": "vertical",
                          "gap": 4,
                          "padding": 16,
                          "children": [
                            {
                              "type": "text",
                              "id": "fIiPj",
                              "name": "codeLine1",
                              "fill": "#E5E5E5",
                              "content": "const doc = new Y.Doc()",
                              "lineHeight": 1.6,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "4A9Do",
                              "name": "codeLine2",
                              "fill": "#E5E5E5",
                              "content": "const provider = new LibP2PProvider(doc, room)",
                              "lineHeight": 1.6,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "iknYw",
                              "name": "codeLine3",
                              "fill": "#E5E5E5",
                              "content": "doc.on('update', broadcastUpdate)",
                              "lineHeight": 1.6,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
