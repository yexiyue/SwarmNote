                                  "content": "const doc = new Y.Doc()",
                                  "lineHeight": 1.6,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
