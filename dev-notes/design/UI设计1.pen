                                  "name": "codeLine1",
                                  "fill": "#E5E5E5",
                                  "content": "const doc = new Y.Doc()",
                                  "lineHeight": 1.6,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "x4j0F",
                                  "name": "codeLine2",
                                  "fill": "#E5E5E5",
                                  "content": "const provider = new LibP2PProvider(doc, room)",
                                  "lineHeight": 1.6,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
