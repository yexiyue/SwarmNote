                                {
                                  "type": "text",
                                  "id": "b75xn",
                                  "name": "codeLine1",
                                  "fill": "#1F1F1F",
                                  "content": "const doc = new Y.Doc()",
                                  "lineHeight": 1.6,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "HLQFW",
                                  "name": "codeLine2",
                                  "fill": "#1F1F1F",
                                  "content": "const provider = new LibP2PProvider(doc, room)",
                                  "lineHeight": 1.6,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "a7Okw",
                                  "name": "codeLine3",
                                  "fill": "#1F1F1F",
                                  "content": "doc.on('update', broadcastUpdate)",
                                  "lineHeight": 1.6,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "LU2Sl",
                              "name": "MergeHighlight",
                              "width": "fill_container",
                              "fill": "#05966920",
