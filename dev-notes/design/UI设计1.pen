            },
            {
              "type": "text",
              "id": "tNPQb",
              "name": "mPara2",
              "fill": "#E5E5E5",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "系统使用 Yjs 作为 CRDT 引擎，所有文档编辑操作被转化为 Y.Doc 的 update 包。",
              "lineHeight": 1.8,
              "fontFamily": "Inter",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
